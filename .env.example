# Public site URL used for metadata/canonical links in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public deployment defaults to content-only mode.
# Leave both flags false to keep paid demos and API routes disabled.
ENABLE_PUBLIC_DEMOS=false
NEXT_PUBLIC_ENABLE_LIVE_DEMOS=false

# Google API key is only needed if you later re-enable the private AI demos.
# Keep secrets server-side only. Do not expose tokens through NEXT_PUBLIC_* variables.
GOOGLE_API_KEY=

# Optional Snowflake credentials for the private Text-to-SQL demo.
# Leave blank for the public content-only deployment.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# Python agent service URLs are only needed if you later re-enable private demos.
# Locally these point at the FastAPI service on port 8787.
# In production on Vercel, set these to your deployed Render service URLs.
ADK_URL=http://127.0.0.1:8787/ask
ADK_PANTRY_URL=http://127.0.0.1:8787/pantry
ADK_HOST=0.0.0.0
ADK_PORT=8787
